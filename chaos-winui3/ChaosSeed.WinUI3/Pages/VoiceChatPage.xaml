<Page
    x:Class="ChaosSeed.WinUI3.Pages.VoiceChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ChaosSeed.WinUI3.Pages"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer>
        <Grid Padding="{StaticResource ChaosPagePadding}" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="10" />
                </TransitionCollection>
            </Grid.Transitions>

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Text="实时对话" FontSize="28" FontWeight="SemiBold" />
                <TextBlock
                    Text="当前版本：仅支持文本输入 → LLM 生成回复 → TTS 流式输出 PCM16（voice.chat.chunk），边收边播。"
                    Opacity="0.8"
                    TextWrapping="Wrap" />
            </StackPanel>

            <muxc:InfoBar
                Grid.Row="1"
                IsOpen="True"
                Severity="Informational"
                Title="提示"
                Message="需要先启动 daemon，并确保已配置 TTS Python 环境（CosyVoice）与 LLM 配置（config/llm.toml）。" />

            <Border Grid.Row="2" Style="{StaticResource ChaosCardBorderStyle}" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="参数" FontSize="18" FontWeight="SemiBold" />
                    <TextBox x:Name="ModelDirBox" Header="modelDir（可空：使用 daemon 侧默认/环境变量）" TextWrapping="Wrap" />
                    <TextBox x:Name="SpkIdBox" Header="spkId（可空：使用 daemon 侧默认）" TextWrapping="Wrap" />
                    <muxc:ToggleSwitch x:Name="ReasoningToggle" Header="思考模式（Reasoning）" OffContent="Normal" OnContent="Reasoning" />
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource ChaosCardBorderStyle}" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="输入" FontSize="18" FontWeight="SemiBold" />
                    <TextBox x:Name="InputTextBox" PlaceholderText="输入文本（将作为 user 消息发送到 LLM）" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="96" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="StartBtn" Content="开始" Click="OnStartClicked" />
                        <Button x:Name="CancelBtn" Content="取消" Click="OnCancelClicked" IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource ChaosCardBorderStyle}" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="状态" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="SessionText" Text="session: (none)" Opacity="0.75" />
                    <TextBlock x:Name="StatusText" Text="status: idle" Opacity="0.75" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
